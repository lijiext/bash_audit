+/* BASH AUDIT: 安全审计日志记录函数
+   双通道日志:
+   1. syslog (主通道 - 防篡改，用户无法直接访问)
+   2. 文件 (辅助通道 - 按用户 UID 隔离)
+      目录: /var/log/bash/ 权限 1733 (sticky bit)
+      文件: audit_<uid>.log 权限 0200 (仅追加写入)
+   增强字段用于 su/sudo 追踪:
+   - login_user: 原始登录用户 (通过 getlogin/SUDO_USER 获取)
+   - euid: 有效 UID (检测权限提升)
+   - ppid: 父进程 ID (追踪进程链)
+   - tty: 终端名称 (审计定位) */
+void
+bash_audit_log (char *line)
+{
+  const char *user_name;
+  const char *login_name;
+  const char *tty_name;
+  char log_path[PATH_MAX];
+  char *escaped, *p, *q;
+  time_t now;
+  struct tm *tm_info;
+  char ts[64];
+  int fd;
+  FILE *fp;
+  struct stat st;
+
+  if (line == 0 || *line == '\0')
+    return;
+
+  user_name = current_user.user_name ? current_user.user_name : "unknown";
+
+  /* 获取原始登录用户名 (跨 su/sudo 追踪) */
+  login_name = getlogin ();
+  if (login_name == NULL)
+    {
+      char *sudo_user = getenv ("SUDO_USER");
+      login_name = sudo_user ? sudo_user : user_name;
+    }
+
+  /* 获取终端名称 */
+  tty_name = ttyname (STDIN_FILENO);
+  if (tty_name == NULL)
+    tty_name = "unknown";
+
+  /* 生成 ISO 8601 时间戳 */
+  now = time (NULL);
+  tm_info = localtime (&now);
+  if (tm_info)
+    strftime (ts, sizeof (ts), "%Y-%m-%dT%H:%M:%S%z", tm_info);
+  else
+    snprintf (ts, sizeof (ts), "unknown");
+
+  /* JSON 转义与单行化处理 */
+  escaped = (char *)xmalloc (strlen (line) * 2 + 1);
+  for (p = line, q = escaped; *p; p++)
+    {
+      if (*p == '"') { *q++ = '\\'; *q++ = '"'; }
+      else if (*p == '\\') { *q++ = '\\'; *q++ = '\\'; }
+      else if (*p == '\n' || *p == '\r' || *p == '\t') { *q++ = ' '; }
+      else if (*p < 32) { *q++ = '?'; }
+      else { *q++ = *p; }
+    }
+  *q = '\0';
+
+  /* 通道 1: syslog (主通道 - 防篡改) */
+  openlog ("bash-audit", LOG_PID | LOG_NDELAY, LOG_LOCAL6);
+  syslog (LOG_INFO,
+    "AUDIT: {\"user\":\"%s\", \"uid\":%d, \"euid\":%d, "
+    "\"login_user\":\"%s\", \"pid\":%d, \"ppid\":%d, "
+    "\"tty\":\"%s\", \"cmd\":\"%s\"}",
+    user_name, (int)current_user.uid, (int)geteuid (),
+    login_name, (int)getpid (), (int)getppid (),
+    tty_name, escaped);
+  closelog ();
+
+  /* 通道 2: 文件 (辅助通道 - 按用户 UID 隔离) */
+  {
+    const char *log_dir = "/var/log/bash";
+
+    /* 尝试创建目录 (权限 1733: sticky + 仅写入/执行) */
+    if (stat (log_dir, &st) != 0)
+      {
+        if (mkdir (log_dir, 01733) == 0)
+          {
+            if (getuid () == 0)
+              {
+                chmod (log_dir, 01733);
+                chown (log_dir, 0, 0);
+              }
+          }
+      }
+
+    /* 按 UID 隔离: audit_<uid>.log */
+    snprintf (log_path, sizeof (log_path), "%s/audit_%d.log",
+              log_dir, (int)getuid ());
+
+    /* O_WRONLY|O_APPEND|O_CREAT: 仅追加写入, 权限 0200 (仅写) */
+    fd = open (log_path, O_WRONLY | O_APPEND | O_CREAT, 0200);
+    if (fd >= 0)
+      {
+        fp = fdopen (fd, "a");
+        if (fp)
+          {
+            fprintf (fp,
+              "{\"time\":\"%s\", \"user\":\"%s\", \"uid\":%d, "
+              "\"euid\":%d, \"login_user\":\"%s\", \"pid\":%d, "
+              "\"ppid\":%d, \"tty\":\"%s\", \"cmd\":\"%s\"}\n",
+              ts, user_name, (int)current_user.uid, (int)geteuid (),
+              login_name, (int)getpid (), (int)getppid (),
+              tty_name, escaped);
+            fclose (fp);
+          }
+        else
+          close (fd);
+      }
+  }
+
+  free (escaped);
+}
+
 #endif /* HISTORY */
